<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <rect width="1080" height="1080" fill="none"/>
  <!-- Outer border -->
  <rect x="20" y="20" width="1040" height="1040" rx="24" ry="24"
        fill="none" stroke="#d4a017" stroke-width="28" opacity="0.85"/>
  <!-- Inner border -->
  <rect x="55" y="55" width="970" height="970" rx="16" ry="16"
        fill="none" stroke="#d4a017" stroke-width="10" opacity="0.45"/>
  <!-- Corner decorations -->
  <text x="60" y="100" font-size="64" opacity="0.7">✨</text>
  <text x="960" y="100" font-size="64" opacity="0.7" text-anchor="middle">✨</text>
  <text x="60" y="1050" font-size="64" opacity="0.7">✨</text>
  <text x="960" y="1050" font-size="64" opacity="0.7" text-anchor="middle">✨</text>
  <!-- Label -->
  <text x="540" y="1040" text-anchor="middle" font-family="Georgia,serif" font-size="22"
        fill="#d4a017" opacity="0.5">Marco Dorado — Replace with real frame PNG</text>
</svg>