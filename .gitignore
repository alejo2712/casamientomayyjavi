# Dependencies
node_modules/
**/node_modules/

# Environment files — NEVER commit these
.env
backend/.env

# Google credentials — NEVER commit
backend/credentials/
credentials/
backend/config/credentials.json
backend/config/tokens.json

# Ignore all JSON except package files and lock files
*.json
!package.json
!package-lock.json
!backend/package.json
!backend/package-lock.json

# Build output
dist/
build/
.next/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

