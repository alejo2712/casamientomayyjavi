# -----------------------------------------------
# Mailen & Javier Wedding Photo Booth — Backend
# Copy this file to .env and fill in the values
# -----------------------------------------------

PORT=3001

# Origins allowed to call this API (comma-separated)
# Use * to allow all (not recommended for production)
ALLOWED_ORIGINS=http://localhost:5500,https://your-frontend-domain.vercel.app

# Google Drive: Option A — Path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

# Google Drive: Option B — Full JSON content as a string (for cloud deployments)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Target Google Drive folder name (will be created if it doesn't exist)
GOOGLE_DRIVE_FOLDER_NAME=Mailen_Javier_Wedding_Photos

# Optional: hard-code a specific folder ID to skip folder lookup
# GOOGLE_DRIVE_FOLDER_ID=1AbcDefGhIjKlMnOp

# Set to "true" if you want the backend to also serve the frontend
SERVE_FRONTEND=false
