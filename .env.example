# ---------------------------------------------------------------
# Wedding Photo Booth — environment template
# ---------------------------------------------------------------
# LOCAL DEV:
#   1. Copy this file to .env (same folder, project root)
#   2. Fill in your real values below
#   3. Never commit .env to git — it is already in .gitignore
#
# PRODUCTION (Render.com):
#   Set these as environment variables in the Render dashboard.
#   Do NOT add a .env file to the repo — Render injects them directly.
# ---------------------------------------------------------------

PORT=3000

# ---------------------------------------------------------------
# Google Drive — OAuth 2.0 credentials
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# ---------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------
# OAuth redirect URI
#
# LOCAL:
#   GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
#
# PRODUCTION (Render):
#   GOOGLE_REDIRECT_URI=https://<your-render-app-name>.onrender.com/oauth2callback
#
# This URI must be registered in Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client → Authorized redirect URIs
# ---------------------------------------------------------------
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# ---------------------------------------------------------------
# Google OAuth refresh token
#
# LOCAL: obtained automatically on first run (saved to backend/config/tokens.json)
#        Leave empty here if tokens.json already exists.
#
# PRODUCTION: REQUIRED — Render has no persistent filesystem.
#   Get the value by running locally:
#     cat backend/config/tokens.json
#   Copy the "refresh_token" value here / into Render env vars.
# ---------------------------------------------------------------
GOOGLE_REFRESH_TOKEN=

# ---------------------------------------------------------------
# Google Drive folder ID
# Open the Drive folder → copy the ID from the URL:
#   https://drive.google.com/drive/folders/← THIS PART →
# ---------------------------------------------------------------
DRIVE_FOLDER_ID=
